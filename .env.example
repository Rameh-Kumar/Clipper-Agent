# ============================
# Clipper Agent — Environment Variables
# ============================
# Copy this file to .env and fill in your values.
# These same values should be set as Modal Secrets for cloud deployment.

# --- Vizard AI (clip generation) ---
VIZARD_API_KEY=your_vizard_api_key_here
VIZARD_TEMPLATE_ID=                          # Optional: Vizard template ID for branded clips
VIZARD_DEFAULT_LANG=en                       # Default language for transcription (en, hi, es, etc.)

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here  # Security: only this chat ID can use the bot

# --- Airtable ---
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here  # Starts with "app"
AIRTABLE_TABLE_NAME=shorts/Reel              # Name of the table in your Airtable base

# --- Blotato (social media publishing) ---
BLOTATO_API_KEY=your_blotato_api_key_here
BLOTATO_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id_here

# --- Modal (auto-set after deployment) ---
MODAL_APP_URL=https://your-workspace--clipper-agent-fastapi-app.modal.run
